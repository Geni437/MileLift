# --- Node / JS ---
node_modules/

# --- Expo ---
.expo/
dist/
web-build/
expo-env.d.ts

# --- Native (generated by prebuild; we use managed/config-plugin workflow) ---
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

# --- Metro ---
.metro-health-check*

# --- debug ---
npm-debug.*
yarn-debug.*
yarn-error.*

# --- macOS ---
.DS_Store
*.pem

# --- Env / secrets ---
# .env holds EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY for local dev.
# Both are safe-for-client values (see app.config.ts comment) but we still don't
# commit the actual local env file — only .env.example is tracked, so a fresh
# checkout doesn't silently run against someone else's values and secrets never
# accumulate in git history even when they're "just" the anon key today.
.env
.env.*.local
.env.local

# --- TypeScript ---
*.tsbuildinfo

# --- Test coverage ---
coverage/

# --- Supabase CLI local state ---
supabase/.temp/
