# Copy this file to `.env` for local development. `.env` is gitignored —
# never commit real values there, even though these two happen to be safe
# for a mobile client (see app.config.ts for why).
#
# EXPO_PUBLIC_SUPABASE_URL and EXPO_PUBLIC_SUPABASE_ANON_KEY are read by
# app.config.ts and exposed to the app via Constants.expoConfig.extra
# (see src/lib/env.ts). The `anon`/`publishable` key is safe to embed in a
# shipped mobile client per standard Supabase practice — it identifies the
# project and is subject to RLS, not a secret credential. The service_role
# key must NEVER appear in this file, in app.config.ts, or anywhere in the
# mobile client.
EXPO_PUBLIC_SUPABASE_URL=https://tjaplaqxsbtwlqkysmkr.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRqYXBsYXF4c2J0d2xxa3lzbWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ0MjQ5NjksImV4cCI6MjEwMDAwMDk2OX0.wMz3FrJWFu3X86Ec2B30qvQe5d9OBNY_kfiNQeQO0Ww

# Phase 1 — Module A (CORE-02 RouteMap). Unlike the two values above, this
# IS a real secret-shaped credential (a Google Maps Android API key,
# typically restricted by package name + SHA-1 fingerprint) — deliberately
# left EMPTY here, not populated with a real value. Without it, the app
# still builds and runs; RouteMap just won't render basemap tiles (see
# app.config.ts's comment). Set a real value only in your local `.env`
# (gitignored) or CI/EAS secrets, never here.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
